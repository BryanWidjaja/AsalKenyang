# AsalKenyang backend environment variables
#
# Copy this file to .env, then fill in the values:
# cp .env.example .env
#
# The real .env holds secrets and is NOT committed (it is listed in .gitignore).
# This .env.example is safe to commit because it only contains placeholders.

# PostgreSQL connection string REQUIRED.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Port 5433 = Postgres from docker-compose; a native Postgres usually uses 5432.
DATABASE_URL="postgresql://asalkenyang:asalkenyang@localhost:5433/asalkenyang?schema=public"

# Secret used to sign JWTs REQUIRED, at least 16 characters.
# Use a long random string. Never commit your real secret to git.
JWT_SECRET="change-me-to-a-long-random-string"

# API server port optional, defaults to 3000.
PORT=3000

# Allowed CORS origins, comma-separated optional, defaults to http://localhost:3000.
# Use "*" to allow any origin (development only).
CORS_ORIGINS="*"
